# === Domain ===
DOMAIN=example.com

# === Forgejo ===
FORGEJO_ROOT_URL=https://git.example.com
FORGEJO_WEBHOOK_ALLOWED_HOSTS=radicle,synedrion,postiz
FORGEJO_CORS_DOMAIN=*
FORGEJO_CORS_SCHEME=https
# Ports default to localhost-only when behind Caddy
# Use 127.0.0.1:PORT to prevent direct external access (Caddy handles it)
FORGEJO_HTTP_PORT=127.0.0.1:3000
FORGEJO_SSH_PORT=
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASS=CHANGE_ME

# Forgejo Actions Runner (generate with: openssl rand -hex 20)
FORGEJO_RUNNER_SECRET=CHANGE_ME

# === Achaean Postgres ===
ACHAEAN_DB_USER=achaean
ACHAEAN_DB_PASS=CHANGE_ME
ACHAEAN_DB_NAME=achaean
ACHAEAN_DB_PORT=127.0.0.1:5432

FORGEJO_ADMIN_USER=aigion-admin
FORGEJO_ADMIN_PASS=CHANGE_ME
FORGEJO_ADMIN_EMAIL=admin@example.com

# === Tuwunel (Matrix) ===
MATRIX_SERVER_NAME=chat.example.com

# === Synedrion ===
SYNEDRION_RUNMODE=staging
SYNEDRION_API_PORT=127.0.0.1:8080
SYNEDRION_INSIGHTS_PORT=127.0.0.1:8081
SYNEDRION_WEB_PORT=127.0.0.1:8082

# === Radicle ===
RADICLE_NODE_PORT=127.0.0.1:8776
RADICLE_HTTP_PORT=127.0.0.1:8880

# === Postiz ===
POSTIZ_PORT=127.0.0.1:4007
POSTIZ_JWT_SECRET=CHANGE_ME
POSTIZ_DB_USER=postiz
POSTIZ_DB_PASS=CHANGE_ME
POSTIZ_DB_NAME=postiz

# === Temporal ===
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASS=CHANGE_ME

